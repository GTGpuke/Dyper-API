# Serveur
PORT=8000
LOG_LEVEL=INFO

# Sécurité — clé interne partagée avec la passerelle dyper-api (header X-Internal-Key). Obligatoire.
# Doit être strictement identique à AI_INTERNAL_KEY côté dyper-api.
AI_INTERNAL_KEY=supersecretkey123

# Modèle YOLO local
# Variante : "yolo26l" (large, défaut) ou "yolo26x" (extra-large, précis).
YOLO_MODEL_VARIANT=yolo26l
# Dossier contenant les fichiers .pt (relatif à dyper-ai/). Le modèle doit y être présent.
YOLO_MODEL_PATH=../model
# Score de confiance minimum (0.0 → 1.0).
YOLO_CONF_THRESHOLD=0.25

# Traitement
IMAGE_MAX_DIM=1280
IMAGE_FETCH_TIMEOUT=10

# Vidéo — durée max (s), cadence d'échantillonnage (img/s) et plafond d'images analysées.
VIDEO_MAX_DURATION_S=300
VIDEO_SAMPLE_FPS=1
VIDEO_MAX_FRAMES=60

# Compréhension multimodale (optionnelle) — active la description riche par modèle vision
# (Llama 4 Scout) et la transcription audio des vidéos (Whisper), via l'API Groq.
# Vide : repli automatique sur la description locale, sans audio.
GROQ_API_KEY=
# Surcharges optionnelles des modèles.
# VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# WHISPER_MODEL=whisper-large-v3-turbo

# Reconnaissance musicale des vidéos (optionnelle, type Shazam) — jeton gratuit sur audd.io.
AUDD_API_TOKEN=

# Détection à vocabulaire ouvert (pipeline « décrire puis ancrer », nécessite GROQ_API_KEY).
# Variante YOLO-World : yolov8x-worldv2 (max, défaut) ; yolov8l-worldv2 / yolov8m-worldv2
# si la VRAM est limitée (ex. RTX 3050). Téléchargée automatiquement au premier démarrage.
# WORLD_MODEL_VARIANT=yolov8x-worldv2
# WORLD_CONF_THRESHOLD=0.1

# Reconnaissance musicale (optionnelle) — identifie la bande-son des vidéos (type Shazam).
# Jeton gratuit sur https://audd.io. Vide : reconnaissance désactivée, sans erreur.
AUDD_API_TOKEN=
