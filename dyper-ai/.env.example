# Serveur
PORT=8000
LOG_LEVEL=INFO

# Sécurité — clé interne partagée avec la passerelle dyper-api (header X-Internal-Key). Obligatoire.
# Doit être strictement identique à AI_INTERNAL_KEY côté dyper-api.
AI_INTERNAL_KEY=supersecretkey123

# Modèle YOLO local
# Variante : "yolo26l" (large, défaut) ou "yolo26x" (extra-large, précis).
YOLO_MODEL_VARIANT=yolo26l
# Dossier contenant les fichiers .pt (relatif à dyper-ai/). Le modèle doit y être présent.
YOLO_MODEL_PATH=../model
# Score de confiance minimum (0.0 → 1.0).
YOLO_CONF_THRESHOLD=0.25

# Traitement
IMAGE_MAX_DIM=1280
IMAGE_FETCH_TIMEOUT=10

# Vidéo — durée max (s), cadence d'échantillonnage (img/s) et plafond d'images analysées.
# VIDEO_SAMPLE_FPS : plus haut = suivi plus précis (moins de mouvement entre frames). VIDEO_MAX_FRAMES
# borne le nombre de frames par vidéo ; relever les deux pour plus de précision (analyse plus longue).
VIDEO_MAX_DURATION_S=300
VIDEO_SAMPLE_FPS=10
VIDEO_MAX_FRAMES=1800
# Coupure de plan : réinitialise le suivi entre clips (compilations). 0 = off ; baisser = + sensible.
# SCENE_CUT_THRESHOLD=0.20
# Nombre minimal de frames où une piste doit apparaître pour être affichée (vidéo) : en deçà, elle
# est jugée fugace (hallucination du vocabulaire ouvert, label parasite) et écartée. 1 = désactivé.
# VIDEO_MIN_TRACK_FRAMES=3

# Compréhension multimodale (optionnelle) — active la description riche par modèle vision
# (Llama 4 Scout) et la transcription audio des vidéos (Whisper), via l'API Groq.
# Vide : repli automatique sur la description locale, sans audio.
GROQ_API_KEY=
# Surcharges optionnelles des modèles.
# VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# WHISPER_MODEL=whisper-large-v3-turbo

# Reconnaissance musicale des vidéos (optionnelle, type Shazam) — jeton gratuit sur audd.io.
AUDD_API_TOKEN=

# Détection à vocabulaire ouvert (YOLO-World) — fusionnée avec COCO pour une couverture maximale.
# Variante YOLO-World : yolov8x-worldv2 (max, défaut) ; yolov8l-worldv2 / yolov8m-worldv2
# si la VRAM est limitée. Téléchargée automatiquement au premier démarrage.
# WORLD_MODEL_VARIANT=yolov8x-worldv2
# Résolution d'inférence (px) — 1280 = petits objets ; abaisser à 640 sur GPU à VRAM limitée.
# WORLD_IMGSZ=1280

# Fusion COCO + vocabulaire ouvert (images & vidéos) — une seule boîte par objet, COCO prioritaire.
# Confiances minimales des détections : COCO et World (scores CLIP plus bas). Baisser pour montrer plus.
# DISPLAY_MIN_CONFIDENCE=0.55
# WORLD_DISPLAY_MIN_CONFIDENCE=0.25
# Marge de bordure (fraction) : écarte en vidéo les objets tronqués par le bord (label ambigu).
# 0 = désactivé. Ex. 0.02 = ignore les détections collées aux 2 % extérieurs du cadre.
# DETECTION_BORDER_MARGIN=0.02
# Seuil IoU au-delà duquel deux boîtes désignent le même objet (fusion).
# MERGE_IOU_THRESHOLD=0.55
# Plafond du vocabulaire ouvert transmis à YOLO-World (éléments vision + base LVIS éventuelle).
# OPEN_VOCAB_MAX=1500
# Inclure la base LVIS (~1200 classes) dans le vocabulaire ouvert des VIDÉOS. true (défaut) : le
# suivi écarte les détections fugaces (VIDEO_MIN_TRACK_FRAMES), donc la large couverture LVIS
# retrouve les objets non décrits par la vision sans laisser passer les hallucinations brèves de
# classes obscures (necklace, birdbath…). Les IMAGES restent toujours ancrées sur la vision (pas de
# filtre temporel) : ce réglage ne les concerne pas. false = vidéos limitées aux éléments décrits.
# OPEN_VOCAB_INCLUDE_BASE=true

# Suivi multi-objets vidéo (tracker maison : mouvement + position + label + apparence). Pondérations
# du coût d'association, pénalité de label (souple), coût max d'appariement, âge max d'une piste sans
# détection (frames). Régler si des identités s'échangent (monter MAX_COST/label) ou se cassent.
# TRACK_W_MOTION=1.0
# TRACK_W_IOU=0.5
# TRACK_W_APPEARANCE=0.4
# TRACK_LABEL_PENALTY=0.3
# TRACK_MAX_COST=1.0
# TRACK_MAX_AGE=30
