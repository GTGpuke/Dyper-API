# ─── Dépendances ─────────────────────────────────────────────────────────────
node_modules/
.venv/
__pycache__/
*.py[cod]

# ─── Variables d'environnement (ne jamais commiter) ──────────────────────────
.env

# ─── Artefacts de build ───────────────────────────────────────────────────────
dist/
build/

# ─── Modèles YOLO (fichiers .pt trop volumineux pour git) ────────────────────
model/*.pt

# ─── Fichiers système ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ─── Uploads temporaires ──────────────────────────────────────────────────────
uploads/
