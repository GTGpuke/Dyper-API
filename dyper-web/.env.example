# URL de la passerelle. EN DÉVELOPPEMENT : laisser VIDE pour passer par le proxy Vite (/api, /health),
# ce qui rend le cookie de session « first-party » (sameSite=lax). En production : URL publique de l'API
# (idéalement même origine que le front, derrière un reverse proxy).
VITE_API_URL=
# Clé applicative envoyée dans le header X-App-Key (doit correspondre à APP_KEY côté dyper-api).
VITE_APP_KEY=
