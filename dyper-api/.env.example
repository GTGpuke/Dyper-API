# Serveur
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Base de données — SQLite (fichier local, créé automatiquement).
DB_STORAGE=./data/dyper.sqlite

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# CORS — origines autorisées (obligatoire), séparées par des virgules. En dev : le front dyper-web (5173).
CORS_ORIGIN=http://localhost:5173

# Sécurité applicative — clé du frontend, transmise dans le header X-App-Key (obligatoire).
# Génération : openssl rand -hex 32
APP_KEY=

# Secret de signature des JWT d'authentification (obligatoire). Génération : openssl rand -hex 32
JWT_SECRET=

# Service d'inférence dyper-ai
AI_SERVICE_URL=http://localhost:8000
# Clé interne partagée avec dyper-ai (header X-Internal-Key, obligatoire).
# Doit être strictement identique à AI_INTERNAL_KEY côté dyper-ai.
AI_INTERNAL_KEY=
# Délai maximum d'attente pour un appel vers dyper-ai (ms).
AI_REQUEST_TIMEOUT_MS=30000
# Délai d'attente dédié au traitement vidéo (ms) — large, car l'analyse parcourt de nombreuses
# images (suivi dense COCO + détection à vocabulaire ouvert sur chaque frame). Relever si besoin.
AI_VIDEO_TIMEOUT_MS=900000

# Upload — taille maximale d'une image (Mo) et d'une vidéo (Mo, durée ≤ 5 min).
MAX_FILE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100

# Chat LLM — clé API Groq (Llama 3.1). Requise pour /api/chat.
GROQ_API_KEY=

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute
