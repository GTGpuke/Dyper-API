{
  "name": "dyper-api",
  "version": "2.0.0",
  "description": "Passerelle API publique Dyper — Fastify / TypeScript (reconnaissance visuelle multimodale)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --import tsx --watch-path=./src src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "stop": "pm2 stop dyper-api",
    "restart": "pm2 restart dyper-api",
    "logs": "pm2 logs dyper-api",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.2",
    "groq-sdk": "^0.9.0",
    "sequelize": "^6.37.3",
    "sqlite3": "^6.0.1",
    "uuid": "^11.1.1",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
